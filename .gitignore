*.npz

# 파이썬 캐시 파일
__pycache__/
*.pyc
*.pyo
*.pyd

# 시스템 및 에디터 설정 파일
.vscode/
.idea/
.DS_Store
Thumbs.db

# 보안 및 환경변수 설정 파일 (API 키 유출 방지)
.env
secret.txt

# Node.js 라이브러리 폴더 (추가)
node_modules/